NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/suchi-ecommerce

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
# Razorpay ─────────────────────────────────────────────────────────────────────
# Sign up at https://dashboard.razorpay.com
# Settings → API Keys → Generate Test Key (for dev) / Live Key (for prod)
RAZORPAY_KEY_ID=rzp_test_SSgWpziSvtsSVu
RAZORPAY_KEY_SECRET=ceV9Yd2P3eGpuou6HDKij0wB

# Razorpay Webhook Secret ─────────────────────────────────────────────────────
# Dashboard → Webhooks → Add Endpoint → copy the "Webhook Secret"
# Set the endpoint URL to: https://your-backend.com/api/payments/webhook
# Enable events: payment.captured, order.paid, payment.failed
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:4200
